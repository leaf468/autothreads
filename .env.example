# AI Trends Reporter - Environment Variables
# Copy this file to .env and fill in your API keys

# Required: Claude API for content generation
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# Required: Google API for Gemini Imagen 3 (Nanobanana) image generation
# Get your key at: https://ai.google.dev/
GOOGLE_API_KEY=AIzaSyxxxxx

# Required: Tavily API for web search (1000 requests/month free)
# Get your key at: https://tavily.com/
TAVILY_API_KEY=tvly-xxxxx

# Optional: OpenAI API (if you want to use GPT-4 instead of Claude)
OPENAI_API_KEY=sk-xxxxx

# GitHub Token (automatically provided by GitHub Actions, no need to set)
GITHUB_TOKEN=ghp_xxxxx
